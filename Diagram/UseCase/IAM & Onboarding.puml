@startuml
title UC-Detail: Phân hệ Xác thực & Định danh (IAM)

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

' --- CẤU HÌNH GIAO DIỆN CHUẨN ---
skinparam usecase {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}
skinparam actor {
    BackgroundColor White
    BorderColor Black
}

' --- ACTORS ---
actor "Admin" as Adm
actor "Authenticated User\n(Nhân viên/Quản lý...)" as User

rectangle "Identity & Access Management (IAM)" {

    ' --- NHÓM AUTHENTICATION (CƠ BẢN) ---
    usecase "Đăng nhập (Login)" as UC_Login
    usecase "Đăng xuất (Logout)" as UC_Logout
    usecase "Quên mật khẩu (Forgot Pass)" as UC_Forgot
    usecase "Bắt buộc đổi mật khẩu" as UC_ForceChange

    ' --- NHÓM SECURITY SETTINGS (CÀI ĐẶT BẢO MẬT) ---
    usecase "Xem hồ sơ cá nhân" as UC_Profile
    usecase "Đổi mật khẩu (Change Pass)" as UC_ChangePass
    usecase "Thiết lập PIN Giao dịch" as UC_SetupPIN
    usecase "Xác thực Mật khẩu hiện tại" as UC_VerifyAuth

    ' --- NHÓM ADMIN MANAGEMENT ---
    usecase "Cấp tài khoản mới (Onboard)" as UC_Onboard
    usecase "Khóa/Mở khóa Tài khoản" as UC_LockUser
    usecase "Sinh mật khẩu & Gửi Email" as UC_SystemGen
}

' --- LIÊN KẾT (ASSOCIATIONS) ---

' 1. ADMIN FLOW
Adm -- UC_Onboard
Adm -- UC_LockUser

' Logic include: Cấp tài khoản tự động sinh pass và gửi mail
UC_Onboard ..> UC_SystemGen : <<include>>

' 2. USER FLOW
User -- UC_Login
User -- UC_Logout
User -- UC_Forgot
User -- UC_Profile
User -- UC_ChangePass
User -- UC_SetupPIN

' Logic Include: Muốn đổi Pass hoặc đổi PIN đều phải nhập Pass hiện tại để xác minh
UC_ChangePass ..> UC_VerifyAuth : <<include>>
UC_SetupPIN ..> UC_VerifyAuth : <<include>>

' Logic Extend: Đăng nhập lần đầu -> Bắt buộc đổi pass
UC_ForceChange .u.> UC_Login : <<extend>>
note right of UC_ForceChange
  Condition:
  is_first_login = true
end note

' Logic PIN
note right of UC_SetupPIN
  Mã PIN 5 số
  (Dùng cho Nạp/Rút tiền)
end note

@enduml